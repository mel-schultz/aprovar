# =====================================================
# CONFIGURAÇÃO SUPABASE - OBRIGATÓRIO!
# =====================================================

# Copie a URL do seu projeto em: Supabase > Settings > API > Project URL
# Exemplo: https://xyzabc123def456.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://mcawdwriqdcvydkorwuv.supabase.co

# Copie a chave anon em: Supabase > Settings > API > Project API Key (anon public)
# Exemplo: eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...
# ⚠️ IMPORTANTE: Use a chave "anon public", não a "service role"
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1jYXdkd3JpcWRjdnlka29yd3V2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM4NTE2NzMsImV4cCI6MjA4OTQyNzY3M30.c1I2ka4FtfbmI3Sutu39NDSgXoK6yzJdFZQ4L1MPlzU

# URL do seu app (usada para redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =====================================================
# INSTRUÇÕES DE SETUP
# =====================================================
# 
# 1. Crie conta em https://supabase.com
# 2. Crie novo projeto (gratuito)
# 3. Vá para Settings > API
# 4. Copie "Project URL" e "Project API Key (anon public)"
# 5. Cole nos campos acima
# 6. Salve este arquivo como .env.local
# 7. Reinicie o servidor: npm run dev
# 8. Execute migrations.sql no Supabase SQL Editor
# 9. Configure CORS: Settings > API > CORS
#    - Adicione: http://localhost:3000
#
# =====================================================
# DÚVIDAS?
# =====================================================
#
# Acesse http://localhost:3000/debug para diagnosticar
# Leia SOLUCAO-DETALHADA-FAILED-FETCH.md para ajuda
#
# =====================================================
