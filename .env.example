# Supabase — copie este arquivo para .env.local e preencha com suas credenciais
# Encontre em: https://app.supabase.com -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY

# Opcional — para notificações via WhatsApp (Twilio)
NEXT_PUBLIC_TWILIO_ACCOUNT_SID=
NEXT_PUBLIC_TWILIO_AUTH_TOKEN=

# URL pública (Vercel preenche automaticamente em produção)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
