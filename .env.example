# Supabase — copie para .env.local e preencha
# https://app.supabase.com → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_ANON_KEY

# URL pública (Vercel preenche automaticamente em produção)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase Service Role Key (NUNCA expor no frontend — apenas em API Routes)
# Encontre em: Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY
