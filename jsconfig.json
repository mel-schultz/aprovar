{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/components/*": ["components/*"],
      "@/lib/*":        ["lib/*"],
      "@/hooks/*":      ["hooks/*"],
      "@/types/*":      ["types/*"],
      "@/app/*":        ["app/*"]
    },
    "jsx": "preserve"
  },
  "include": ["**/*.js", "**/*.jsx"],
  "exclude": ["node_modules", ".next"]
}
